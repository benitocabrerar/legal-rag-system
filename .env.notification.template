# ============================================
# Notification Service Configuration
# ============================================
# Copy these variables to your .env file and fill in your credentials

# -------------------
# Twilio SMS (BE-006)
# -------------------
# Get these from: https://console.twilio.com/
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# -------------------
# Firebase Push (BE-007)
# -------------------
# Get these from: Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# Note: The private key should include \n for line breaks
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# -------------------
# SendGrid Email (BE-008)
# -------------------
# Get this from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional: Configure the "from" email address for backup notifications
NOTIFICATION_FROM_EMAIL=backups@legal-rag.com

# ============================================
# Testing Notes:
# ============================================
# 1. Twilio: Start with a verified phone number in development
# 2. Firebase: Generate service account key from Firebase Console
# 3. SendGrid: Verify sender email before sending to avoid spam filters
#
# For production: Use secret management service (AWS Secrets Manager, etc.)
