# PostgreSQL en Render
DATABASE_URL="postgresql://user:password@host.oregon-postgres.render.com:5432/database?sslmode=require"

# OpenAI API Key
OPENAI_API_KEY="sk-..."

# Configuración de embeddings
EMBEDDING_MODEL="text-embedding-ada-002"
EMBEDDING_DIMENSIONS=1536

# Límites de planes
MAX_CASES_FREE=5
MAX_CASES_BASIC=50
MAX_CASES_PROFESSIONAL=200
MAX_CASES_TEAM=1000

# AWS S3 para documentos
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="..."
AWS_SECRET_ACCESS_KEY="..."
AWS_S3_BUCKET="legal-rag-documents"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="tu-secret-aleatorio"

# Stripe (opcional)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."

# SendGrid Email Service
SENDGRID_API_KEY="SG...."
FROM_EMAIL="noreply@poweria-legal.com"
FROM_NAME="Poweria Legal"

# ─── Telegram Bot ───────────────────────────────────────────────────
# Token del bot creado con @BotFather
TELEGRAM_BOT_TOKEN="123456789:ABC-DEF..."
# @handle del bot SIN el @ (para los deep links de vinculación)
TELEGRAM_BOT_USERNAME="PoweriaLegalBot"
# Secret aleatorio — Telegram lo reenvía en cada update (anti-spoofing).
# Generar con: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET="..."
# Chat ID del operador COGNITEX para alertas de sistema (de @userinfobot)
TELEGRAM_ADMIN_CHAT_ID="..."
# URL pública del backend (para auto-registrar el webhook)
PUBLIC_API_URL="https://poweria-legal-api.onrender.com"
