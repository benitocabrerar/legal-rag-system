# =============================================================================
# Variables de entorno para la migración a Supabase
# =============================================================================
# Copiar este archivo a .env (junto a las variables actuales) cuando inicie
# la Fase 0 del plan de migración. NO reemplazar el .env existente todavía.
# =============================================================================

# ----- Supabase project -----
# Dashboard → Project Settings → API
SUPABASE_URL="https://xxxxxxxxxxxxxxxx.supabase.co"
SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIs..."
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIs..."  # ⚠️  SOLO BACKEND. NUNCA al frontend ni al cliente.

# ----- Postgres directo (Prisma + scripts) -----
# Dashboard → Project Settings → Database → Connection string (Session mode)
# Mantener el DATABASE_URL actual de Render hasta cutover de Fase 4.
SUPABASE_DATABASE_URL="postgresql://postgres.xxxxxxxx:PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres?sslmode=require"

# Para migrations (Session pooler, port 5432). Para queries de app, preferir transaction pooler (port 6543).
SUPABASE_DATABASE_URL_TX="postgresql://postgres.xxxxxxxx:PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true"

# ----- Frontend (Next.js) -----
NEXT_PUBLIC_SUPABASE_URL="https://xxxxxxxxxxxxxxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIs..."

# ----- Storage -----
SUPABASE_STORAGE_BUCKET_DOCUMENTS="legal-documents"
SUPABASE_STORAGE_BUCKET_AVATARS="user-avatars"
SUPABASE_STORAGE_BUCKET_BACKUPS="backups"

# ----- Feature flags de migración -----
# 'shadow' = lee Render, escribe a ambos (dual-write Fase 4 fase a)
# 'canary' = lee X% Supabase, resto Render (Fase 4 fase b)
# 'enforce' = lee/escribe solo Supabase (post-cutover)
MIGRATION_MODE="shadow"
CANARY_PERCENT="0"

# RLS enforcement durante Fase 2:
# 'permissive' = policies con USING (true) — auditar sin bloquear
# 'strict'     = policies reales aplicadas
RLS_ENFORCEMENT_MODE="permissive"

# ----- Re-embedding job -----
EMBEDDING_MODEL="text-embedding-3-small"     # Único modelo válido post-migración
EMBEDDING_DIMENSIONS=1536
REEMBED_BATCH_SIZE=100                        # chunks por batch
REEMBED_RATE_LIMIT_RPM=3000                   # tokens/min OpenAI tier

# ----- JWT Custom claims hook -----
# Activar en Dashboard → Authentication → Hooks → "Custom Access Token"
# Apunta a public.custom_access_token_hook (creado en migration 0004)
