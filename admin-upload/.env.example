# 🚀 POWERIA Legal - Admin Upload Server
# Copia este archivo a .env y configura tus valores

# ============================================================================
# DATABASE
# ============================================================================
# Usa la misma DATABASE_URL del proyecto principal
DATABASE_URL="postgresql://user:password@localhost:5432/poweria_legal"

# ============================================================================
# OPENAI API
# ============================================================================
OPENAI_API_KEY="sk-..."

# ============================================================================
# SERVER CONFIGURATION (Opcional)
# ============================================================================
# Puerto del servidor (por defecto: 3333)
ADMIN_UPLOAD_PORT=3333

# Secret para JWT (se genera automáticamente si no se especifica)
JWT_SECRET="tu-secreto-muy-seguro-aqui"

# ============================================================================
# ENVIRONMENT (Opcional)
# ============================================================================
NODE_ENV=development
